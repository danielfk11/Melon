ASPNETCORE_ENVIRONMENT=Production

# Copy this file to /etc/melonmq/melonmq.env and replace blank secrets before start.

MelonMQ__TcpBindAddress=0.0.0.0
MelonMQ__TcpPort=5672
MelonMQ__HttpPort=9090
MelonMQ__DataDirectory=/var/lib/melonmq
MelonMQ__Backpressure__MaxEnqueueWaitMs=1000

MelonMQ__TcpTls__Enabled=true
MelonMQ__TcpTls__CertificatePath=/etc/melonmq/certs/production-server.pfx
MelonMQ__TcpTls__CertificatePassword=
MelonMQ__TcpTls__CheckCertificateRevocation=true

MelonMQ__Security__RequireAuth=true
MelonMQ__Security__RequireHashedPasswords=true
MelonMQ__Security__RequireAdminApiKey=true
MelonMQ__Security__ProtectReadEndpoints=true
MelonMQ__Security__AllowedOrigins__0=https://melonmq.example
MelonMQ__Security__Users__producer=
MelonMQ__Security__Users__consumer=
MelonMQ__Security__ApiKeys__0__Name=ops-admin
MelonMQ__Security__ApiKeys__0__Key=
MelonMQ__Security__ApiKeys__0__Role=admin
MelonMQ__Security__ApiKeys__1__Name=ops-readonly
MelonMQ__Security__ApiKeys__1__Key=
MelonMQ__Security__ApiKeys__1__Role=read

MelonMQ__Observability__Prometheus__Enabled=true
MelonMQ__Observability__Prometheus__EndpointPath=/metrics
MelonMQ__Observability__Prometheus__RequireAdminApiKey=true
MelonMQ__Observability__Otlp__Enabled=false
MelonMQ__Observability__LocalStack__Enabled=false

MelonMQ__Cluster__Enabled=false
MelonMQ__Cluster__NodeId=node-1
MelonMQ__Cluster__NodeAddress=https://node-1.melonmq.example
MelonMQ__Cluster__SharedKey=
