{
  "MelonMQ": {
    "TcpBindAddress": "127.0.0.1",
    "TcpTls": {
      "Enabled": false
    },
    "Security": {
      "RequireAuth": false,
      "RequireHashedPasswords": false,
      "RequireAdminApiKey": false,
      "ProtectReadEndpoints": false,
      "AllowedOrigins": [
        "http://localhost:3000",
        "http://localhost:5173",
        "http://localhost:9090"
      ]
    },
    "Observability": {
      "Prometheus": {
        "Enabled": true,
        "EndpointPath": "/metrics",
        "RequireAdminApiKey": false
      },
      "Otlp": {
        "Enabled": false
      }
    },
    "Cluster": {
      "Enabled": false,
      "NodeId": "dev-node-1",
      "NodeAddress": "http://127.0.0.1:9090",
      "SeedNodes": [],
      "SharedKey": "dev-cluster-key",
      "DiscoveryIntervalSeconds": 3,
      "NodeTimeoutSeconds": 10,
      "EnableReplication": true,
      "RequireQuorumForWrites": false,
      "Consistency": "leader"
    }
  }
}
